<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <Package Version="5">
    <PathDelim Value="\"/>
    <Name Value="IM_forms"/>
    <Type Value="RunAndDesignTime"/>
    <CompilerOptions>
      <Version Value="11"/>
      <PathDelim Value="\"/>
      <SearchPaths>
        <IncludeFiles Value="src\Display\Forms;src\Display\Frames;src\Display\Wizards"/>
        <OtherUnitFiles Value="src\Display\Forms;src\Display\Frames;src\Classes;src\Support;src\Display\Wizards"/>
        <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
      </SearchPaths>
    </CompilerOptions>
    <Files>
      <Item>
        <Filename Value="src\Classes\ControlGridLayout.pas"/>
        <UnitName Value="ControlGridLayout"/>
      </Item>
