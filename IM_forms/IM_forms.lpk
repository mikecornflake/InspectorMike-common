      </Item>
      <Item>
        <Filename Value="src\Display\Frames\FrameHTMLs.pas"/>
        <UnitName Value="FrameHTMLs"/>
      </Item>
      <Item>
        <Filename Value="src\Support\ControlsSupport.pas"/>
        <UnitName Value="ControlsSupport"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Wizards\WizardBase.lfm"/>
        <Type Value="LFM"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Wizards\WizardBase.pas"/>
        <UnitName Value="WizardBase"/>
      </Item>
      <Item>
        <Filename Value="src\Classes\PipelineEventMap.pas"/>
        <UnitName Value="PipelineEventMap"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Frames\FramePipelineView.pas"/>
        <UnitName Value="FramePipelineView"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Frames\FramePipelineView.lfm"/>
        <Type Value="LFM"/>
      </Item>
    </Files>
    <RequiredPkgs>
      <Item>
        <PackageName Value="SynEditDsgn"/>
      </Item>
      <Item>
        <PackageName Value="SynEdit"/>
      </Item>
      <Item>
        <PackageName Value="TurboPowerIPro"/>
      </Item>
      <Item>
        <PackageName Value="IM_units"/>
      </Item>
      <Item>
        <PackageName Value="LCLBase"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPkgs>
    <UsageOptions>
      <UnitPath Value="$(PkgOutDir)"/>
    </UsageOptions>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
  </Package>
