        <Filename Value="src\Display\Forms\FormPersistent.lfm"/>
        <Type Value="LFM"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Forms\FormPersistent.pas"/>
        <UnitName Value="FormPersistent"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Frames\FrameBase.lfm"/>
