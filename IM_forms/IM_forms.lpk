      </Item>
      <Item>
        <Filename Value="src\Display\Frames\FrameBase.pas"/>
        <UnitName Value="FrameBase"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Forms\FormAbout.lfm"/>
        <Type Value="LFM"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Forms\FormAbout.pas"/>
        <UnitName Value="FormAbout"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Forms\FormMain.lfm"/>
        <Type Value="LFM"/>
      </Item>
      <Item>
        <Filename Value="src\Display\Forms\FormMain.pas"/>
